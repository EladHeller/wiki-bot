{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "sourceMap": true,
        "strict": true,
        "useUnknownInCatchVariables": false
    },
    "include": [
        "bot",
        "testConfig",
        "xmlbot"
    ]
}