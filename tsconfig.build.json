{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "rootDir": "bot",
        "outDir": "dist",
        "strict": true,
        "useUnknownInCatchVariables": false
    },
    "include": ["bot"],
    "exclude": ["bot/__tests__"]
}
